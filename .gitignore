# 数据目录只保留最终训练集和 benchmark，其余中间产物不入库
data/generated/
data/manual_seed/
data/SFT_data/
data/**/drafts/
data/**/.json
!data/train_data/data_v1.json
!data/benchmark/*.json
!data/final/raw/*.jsonl
!data/final/processed/*.jsonl

# 忽略临时数据输出模型
output/

# 忽略运行缓存和虚机环境
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/
.vscode/
.venv/
wandb/
logs/
*.log

# Ignore huggingface and torch temp data (if applicable on local runs)
.cache/
